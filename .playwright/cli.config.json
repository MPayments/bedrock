{
  "browser": {
    "browserName": "chromium",
    "userDataDir": ".playwright/user-data",
    "launchOptions": {
      "headless": true
    },
    "contextOptions": {
      "viewport": {
        "width": 1440,
        "height": 900
      }
    }
  },
  "outputDir": "artifacts/playwright-cli",
  "outputMode": "file",
  "saveVideo": {
    "width": 1440,
    "height": 900
  },
  "console": {
    "level": "warning"
  },
  "network": {
    "allowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:3002",
      "http://localhost:3003"
    ]
  },
  "testIdAttribute": "data-testid",
  "timeouts": {
    "action": 7000,
    "navigation": 60000
  },
  "codegen": "typescript"
}
