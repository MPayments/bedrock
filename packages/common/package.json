{
  "name": "@multihansa/common",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/common/index.ts",
    "./currency": "./src/common/currency.ts",
    "./errors": "./src/common/errors.ts",
    "./pagination": "./src/common/pagination.ts",
    "./constants": "./src/common/constants.ts",
    "./math": "./src/common/math.ts",
    "./utils": "./src/common/utils.ts",
    "./countries": "./src/countries/index.ts",
    "./countries/contracts": "./src/countries/contracts.ts",
    "./zod": "./src/zod/index.ts",
    "./zod/*": "./src/zod/*.ts",
    "./sql": "./src/sql/index.ts",
    "./sql/*": "./src/sql/*.ts",
    "./operations": "./src/operations/index.ts",
    "./operations/schema": "./src/operations/schema.ts",
    "./operations/*": "./src/operations/*.ts",
    "./registers": "./src/registers/index.ts",
    "./registers/*": "./src/registers/*.ts",
    "./workers": "./src/workers/index.ts",
    "./workers/*": "./src/workers/*.ts",
    "./bedrock": "./src/bedrock/index.ts",
    "./bedrock/*": "./src/bedrock/*.ts"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsc --watch",
    "check-types": "tsgo --noEmit",
    "lint": "eslint src/**/*.ts --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/core": "workspace:*",
    "@bedrock/security": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.3"
  }
}
