{
  "name": "@bedrock/workflow-customer-portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.test.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@bedrock/calculations": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/deals": "workspace:*",
    "@bedrock/iam": "workspace:*",
    "@bedrock/parties": "workspace:*",
    "@bedrock/platform": "workspace:*",
    "@bedrock/shared": "workspace:*"
  },
  "devDependencies": {
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "bedrock": {
    "kind": "workflow",
    "tags": [
      "workflow",
      "customer-portal"
    ]
  }
}
