{
  "name": "@bedrock/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./accounting": "./src/accounting/index.ts",
    "./accounting/contracts": "./src/accounting/contracts.ts",
    "./accounting/validation": "./src/accounting/validation.ts",
    "./balances": "./src/balances/index.ts",
    "./component-runtime": "./src/component-runtime/index.ts",
    "./connectors": "./src/connectors/index.ts",
    "./counterparties": "./src/counterparties/index.ts",
    "./counterparties/contracts": "./src/counterparties/contracts.ts",
    "./counterparties/validation": "./src/counterparties/validation.ts",
    "./currencies": "./src/currencies/index.ts",
    "./currencies/contracts": "./src/currencies/contracts.ts",
    "./customers": "./src/customers/index.ts",
    "./customers/contracts": "./src/customers/contracts.ts",
    "./customers/validation": "./src/customers/validation.ts",
    "./dimensions": "./src/dimensions/index.ts",
    "./documents": "./src/documents/index.ts",
    "./documents/contracts": "./src/documents/contracts.ts",
    "./documents/module-kit": "./src/documents/module-kit/index.ts",
    "./documents/worker": "./src/documents/worker.ts",
    "./documents/validation": "./src/documents/validation.ts",
    "./idempotency": "./src/idempotency/index.ts",
    "./ledger": "./src/ledger/index.ts",
    "./ledger/worker": "./src/ledger/worker.ts",
    "./ledger/tb": "./src/ledger/tb.ts",
    "./operational-accounts": "./src/operational-accounts/index.ts",
    "./operational-accounts/contracts": "./src/operational-accounts/contracts.ts",
    "./operational-accounts/validation": "./src/operational-accounts/validation.ts",
    "./orchestration": "./src/orchestration/index.ts",
    "./reconciliation": "./src/reconciliation/index.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "pack:validate": "bun x tsx ./scripts/accounting/pack-validate.ts",
    "pack:compile": "bun x tsx ./scripts/accounting/pack-compile.ts",
    "pack:activate": "bun x tsx ./scripts/accounting/pack-activate.ts"
  },
  "dependencies": {
    "@bedrock/db": "workspace:*",
    "@bedrock/foundation": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "tigerbeetle-node": "^0.16.72",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bedrock/eslint-config": "workspace:*",
    "@bedrock/test-utils": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.15.5",
    "eslint": "^9.31.0",
    "pg": "^8.16.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
