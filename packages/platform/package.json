{
  "name": "@bedrock/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./auth-betterauth": "./src/auth-betterauth/index.ts",
    "./auth-betterauth/*": "./src/auth-betterauth/*.ts",
    "./auth-model": "./src/auth-model/index.ts",
    "./auth-model/*": "./src/auth-model/*.ts",
    "./crypto": "./src/crypto/index.ts",
    "./crypto/*": "./src/crypto/*.ts",
    "./idempotency": "./src/idempotency/index.ts",
    "./idempotency/*": "./src/idempotency/*.ts",
    "./idempotency-postgres": "./src/idempotency-postgres/index.ts",
    "./idempotency-postgres/*": "./src/idempotency-postgres/*.ts",
    "./observability": "./src/observability/index.ts",
    "./observability/*": "./src/observability/*.ts",
    "./persistence": "./src/persistence/index.ts",
    "./persistence/*": "./src/persistence/*.ts",
    "./postgres": "./src/postgres/index.ts",
    "./postgres/*": "./src/postgres/*.ts",
    "./postgres/schema": "./src/postgres/schema/index.ts",
    "./postgres/schema/*": "./src/postgres/schema/*.ts",
    "./worker-runtime": "./src/worker-runtime/index.ts",
    "./worker-runtime/*": "./src/worker-runtime/*.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:nuke": "node ./scripts/db-nuke.mjs",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@bedrock/accounting": "workspace:*",
    "@bedrock/balances": "workspace:*",
    "@bedrock/counterparties": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/customers": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@bedrock/fees": "workspace:*",
    "@bedrock/fx": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "@bedrock/organizations": "workspace:*",
    "@bedrock/reconciliation": "workspace:*",
    "@bedrock/requisites": "workspace:*",
    "@bedrock/shared": "workspace:*",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@bedrock/eslint-config": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.31.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "bedrock": {
    "kind": "platform",
    "tags": [
      "platform"
    ]
  }
}
