{
  "name": "@bedrock/sdk-api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "node -e \"console.log('sdk-api-client exports source files; no build output')\"",
    "dev": "tsc --watch",
    "check-types": "tsgo --noEmit",
    "lint": "eslint src/**/*.ts --ignore-pattern \"src/**/*.d.ts\" --max-warnings 0"
  },
  "dependencies": {
    "api": "workspace:*",
    "hono": "^4.12.2"
  },
  "devDependencies": {
    "@bedrock/eslint-config": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3"
  },
  "bedrock": {
    "kind": "sdk",
    "tags": [
      "sdk",
      "api"
    ]
  }
}
