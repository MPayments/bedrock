{
  "name": "@bedrock/finance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./assets": "./src/assets/index.ts",
    "./assets/schema": "./src/assets/schema.ts",
    "./assets/*": "./src/assets/*.ts",
    "./accounting": "./src/accounting/index.ts",
    "./accounting/schema": "./src/accounting/schema.ts",
    "./accounting/*": "./src/accounting/*.ts",
    "./balances": "./src/balances/index.ts",
    "./balances/schema": "./src/balances/schema.ts",
    "./balances/*": "./src/balances/*.ts",
    "./ledger": "./src/ledger/index.ts",
    "./ledger/schema": "./src/ledger/schema/index.ts",
    "./ledger/schema/*": "./src/ledger/schema/*.ts",
    "./ledger/*": "./src/ledger/*.ts",
    "./reconciliation": "./src/reconciliation/index.ts",
    "./reconciliation/schema": "./src/reconciliation/schema.ts",
    "./reconciliation/*": "./src/reconciliation/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "pack:validate": "tsx ./scripts/pack-validate.ts",
    "pack:compile": "tsx ./scripts/pack-compile.ts",
    "pack:activate": "tsx ./scripts/pack-activate.ts"
  },
  "dependencies": {
    "@bedrock/common": "workspace:*",
    "@bedrock/platform": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "tigerbeetle-node": "^0.16.72",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
