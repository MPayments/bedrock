{
  "name": "@bedrock/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./operations": "./src/operations/index.ts",
    "./operations/schema": "./src/operations/schema.ts",
    "./operations/*": "./src/operations/*.ts",
    "./identity": "./src/identity/index.ts",
    "./identity/schema": "./src/identity/schema.ts",
    "./identity/validation": "./src/identity/users/validation.ts",
    "./identity/*": "./src/identity/*.ts",
    "./registers": "./src/registers/index.ts",
    "./registers/*": "./src/registers/*.ts",
    "./workflows": "./src/workflows/index.ts",
    "./workflows/*": "./src/workflows/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/common": "workspace:*",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3"
  }
}
