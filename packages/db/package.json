{
  "name": "@bedrock/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/accounting": "./src/schema/accounting.ts",
    "./schema/balances": "./src/schema/balances.ts",
    "./schema/component-runtime": "./src/schema/component-runtime.ts",
    "./schema/connectors": "./src/schema/connectors.ts",
    "./schema/counterparties": "./src/schema/counterparties.ts",
    "./schema/currencies": "./src/schema/currencies.ts",
    "./schema/customers": "./src/schema/customers.ts",
    "./schema/documents": "./src/schema/documents.ts",
    "./schema/fees": "./src/schema/fees/index.ts",
    "./schema/fx": "./src/schema/fx/index.ts",
    "./schema/idempotency": "./src/schema/idempotency.ts",
    "./schema/ledger": "./src/schema/ledger/index.ts",
    "./schema/operational-accounts": "./src/schema/operational-accounts/index.ts",
    "./schema/orchestration": "./src/schema/orchestration.ts",
    "./schema/reconciliation": "./src/schema/reconciliation.ts",
    "./seeds": "./src/seeds/index.ts"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsc --watch",
    "check-types": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:nuke": "node ./scripts/db-nuke.mjs",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx ./src/seeds/run-all.ts",
    "db:seed:accounting": "tsx ./src/seeds/run-accounting.ts",
    "db:bootstrap:accounting": "tsx ./src/seeds/run-accounting.ts",
    "db:bootstrap:v2-core": "tsx ./src/seeds/run-accounting.ts",
    "db:seed:users": "tsx ./src/seeds/run-users.ts",
    "db:seed:counterparties": "tsx ./src/seeds/run-counterparties.ts",
    "db:seed:account-providers": "tsx ./src/seeds/run-account-providers.ts",
    "db:seed:accounts": "tsx ./src/seeds/run-accounts.ts",
    "lint": "eslint src/**/*.ts --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/foundation": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.2"
  },
  "devDependencies": {
    "@bedrock/eslint-config": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/pg": "^8.16.0",
    "better-auth": "*",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
