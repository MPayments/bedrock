{
  "name": "@multihansa/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts",
    "./seeds": "./src/seeds/index.ts"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsc --watch",
    "check-types": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:nuke": "node ./scripts/db-nuke.mjs",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx ./src/seeds/run-all.ts",
    "db:seed:accounting": "tsx ./src/seeds/run-accounting.ts",
    "db:bootstrap:accounting": "tsx ./src/seeds/run-accounting.ts",
    "db:bootstrap:v2-core": "tsx ./src/seeds/run-accounting.ts",
    "db:seed:users": "tsx ./src/seeds/run-users.ts",
    "db:seed:counterparties": "tsx ./src/seeds/run-counterparties.ts",
    "db:seed:organizations": "tsx ./src/seeds/run-organizations.ts",
    "db:seed:requisite-providers": "tsx ./src/seeds/run-requisite-providers.ts",
    "db:seed:requisites": "tsx ./src/seeds/run-requisites.ts",
    "lint": "eslint src/**/*.ts --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/accounting": "workspace:*",
    "@multihansa/accounting-reporting": "workspace:*",
    "@bedrock/assets": "workspace:*",
    "@bedrock/balances": "workspace:*",
    "@multihansa/app": "workspace:*",
    "@multihansa/counterparties": "workspace:*",
    "@multihansa/customers": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@multihansa/fees": "workspace:*",
    "@multihansa/fx": "workspace:*",
    "@bedrock/identity": "workspace:*",
    "@bedrock/common": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "@bedrock/modules": "workspace:*",
    "@bedrock/operations": "workspace:*",
    "@multihansa/organizations": "workspace:*",
    "@bedrock/reconciliation": "workspace:*",
    "@multihansa/requisite-providers": "workspace:*",
    "@multihansa/requisites": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.2"
  },
  "devDependencies": {
    "@multihansa/eslint-config": "workspace:*",
    "@multihansa/typescript-config": "workspace:*",
    "@types/pg": "^8.16.0",
    "better-auth": "*",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
