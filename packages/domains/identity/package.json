  },
  "dependencies": {
    "@bedrock/core": "workspace:*",
    "@bedrock/security": "workspace:*",
    "@multihansa/common": "workspace:*",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3"
