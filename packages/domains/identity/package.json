{
  "name": "@multihansa/identity",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/identity/index.ts",
    "./schema": "./src/identity/schema.ts",
    "./validation": "./src/identity/users/validation.ts",
    "./*": "./src/identity/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
