{
  "name": "@multihansa/treasury",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./payments": "./src/payments/index.ts",
    "./payments/*": "./src/payments/*.ts",
    "./fees": "./src/fees/index.ts",
    "./fees/schema": "./src/fees/schema/index.ts",
    "./fees/schema/*": "./src/fees/schema/*.ts",
    "./fees/*": "./src/fees/*.ts",
    "./fx": "./src/fx/index.ts",
    "./fx/schema": "./src/fx/schema/index.ts",
    "./fx/schema/*": "./src/fx/schema/*.ts",
    "./fx/*": "./src/fx/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/common": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@bedrock/finance": "workspace:*",
    "@multihansa/parties": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "soap": "^1.6.0",
    "tlsclientwrapper": "^4.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3"
  }
}
