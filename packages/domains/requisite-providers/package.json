{
  "name": "@multihansa/requisite-providers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./contracts": "./src/contracts.ts",
    "./validation": "./src/validation.ts",
    "./manifest": "./src/manifest.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/kernel": "workspace:*",
    "@multihansa/requisites": "workspace:*",
    "@bedrock/sql": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@multihansa/eslint-config": "workspace:*",
    "@multihansa/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3"
  }
}
