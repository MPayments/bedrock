    "@bedrock/identity": "workspace:*",
    "@bedrock/registers": "workspace:*",
    "@bedrock/counterparties": "workspace:*",
    "@bedrock/customers": "workspace:*",
    "@bedrock/organizations": "workspace:*",
    "@bedrock/requisite-providers": "workspace:*",
    "@bedrock/requisites": "workspace:*",
    "@bedrock/payments": "workspace:*",
    "@bedrock/fx": "workspace:*",
    "@bedrock/fees": "workspace:*",
    "@bedrock/ifrs-documents": "workspace:*",
    "@bedrock/accounting-reporting": "workspace:*",
    "@bedrock/documents": "workspace:*",
