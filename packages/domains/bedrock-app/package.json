  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./module-runtime": "./src/module-runtime/index.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
