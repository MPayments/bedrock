{
  "name": "@multihansa/parties",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./counterparties": "./src/counterparties/index.ts",
    "./counterparties/*": "./src/counterparties/*.ts",
    "./customers": "./src/customers/index.ts",
    "./customers/*": "./src/customers/*.ts",
    "./organizations": "./src/organizations/index.ts",
    "./organizations/*": "./src/organizations/*.ts",
    "./requisites": "./src/requisites/index.ts",
    "./requisites/*": "./src/requisites/*.ts",
    "./requisite-providers": "./src/requisite-providers/index.ts",
    "./requisite-providers/*": "./src/requisite-providers/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0"
  },
  "dependencies": {
    "@multihansa/accounting": "workspace:*",
    "@multihansa/assets": "workspace:*",
    "@multihansa/common": "workspace:*",
    "@multihansa/ledger": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3"
  }
}
