{
  "name": "@multihansa/ledger",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/ledger/index.ts",
    "./account-no": "./src/ledger/account-no.ts",
    "./schema": "./src/ledger/schema/index.ts",
    "./schema/*": "./src/ledger/schema/*.ts",
    "./scopes": "./src/ledger/scopes.ts",
    "./*": "./src/ledger/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
