  },
  "dependencies": {
    "@multihansa/common": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "tigerbeetle-node": "^0.16.72",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3"
  }
}
