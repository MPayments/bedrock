{
  "name": "@multihansa/accounting",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/accounting/index.ts",
    "./schema": "./src/accounting/schema.ts",
    "./*": "./src/accounting/*.ts"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "pack:validate": "tsx ./scripts/pack-validate.ts",
    "pack:compile": "tsx ./scripts/pack-compile.ts",
    "pack:activate": "tsx ./scripts/pack-activate.ts"
  },
  "dependencies": {
    "@multihansa/common": "workspace:*",
    "@multihansa/ledger": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
