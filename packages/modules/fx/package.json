{
  "name": "@bedrock/fx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts.ts",
    "./schema": "./src/schema/index.ts",
    "./worker": "./src/worker.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@bedrock/adapter-db-drizzle": "workspace:*",
    "@bedrock/adapter-worker-runtime": "workspace:*",
    "@bedrock/counterparties": "workspace:*",
    "@bedrock/core": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@bedrock/fees": "workspace:*",
    "@bedrock/money": "workspace:*",
    "@bedrock/observability": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bedrock/integration-fx-providers": "workspace:*",
    "@bedrock/test-utils": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "eslint": "^9.31.0",
    "pg": "^8.18.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "bedrock": {
    "kind": "module",
    "tags": [
      "module",
      "fx"
    ]
  }
}
