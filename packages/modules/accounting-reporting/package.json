{
  "name": "@bedrock/accounting-reporting",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts.ts",
    "./schema": "./src/schema/index.ts",
    "./validation": "./src/validation.ts",
    "./dimensions": "./src/dimensions/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@bedrock/accounting": "workspace:*",
    "@bedrock/balances": "workspace:*",
    "@bedrock/common": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "@bedrock/parties": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18",
    "@types/pg": "^8.16.0",
    "pg": "^8.18.0"
  }
}
