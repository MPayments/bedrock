{
  "name": "@bedrock/accounting",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants.ts",
    "./contracts": "./src/contracts.ts",
    "./schema": "./src/schema.ts",
    "./adapters/drizzle": "./src/adapters/drizzle.ts",
    "./posting-contracts": "./src/posting-contracts.ts",
    "./packs/schema": "./src/packs/schema.ts",
    "./packs/raw-pack": "./src/packs/raw-pack.ts",
    "./packs/bedrock-core-default": "./src/packs/bedrock-core-default.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-assets.mjs",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "pack:validate": "tsx ./scripts/pack-validate.ts",
    "pack:compile": "tsx ./scripts/pack-compile.ts",
    "pack:activate": "tsx ./scripts/pack-activate.ts"
  },
  "dependencies": {
    "@bedrock/parties": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11",
    "@bedrock/platform": "workspace:*",
    "@bedrock/shared": "workspace:*"
  },
  "devDependencies": {
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "eslint": "^10.2.0",
    "pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "bedrock": {
    "kind": "module",
    "tags": [
      "module",
      "accounting"
    ]
  }
}
