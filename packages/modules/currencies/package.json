{
  "name": "@bedrock/currencies",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./queries": "./src/queries.ts",
    "./schema": "./src/infra/drizzle/schema/index.ts",
    "./catalog": "./src/catalog.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11",
    "@bedrock/platform": "workspace:*",
    "@bedrock/shared": "workspace:*"
  },
  "devDependencies": {
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "bedrock": {
    "kind": "module",
    "tags": [
      "module",
      "currencies"
    ]
  }
}
