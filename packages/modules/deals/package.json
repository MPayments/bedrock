    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bedrock/eslint-config": "workspace:*",
    "@bedrock/test-utils": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "eslint": "^10.2.0",
