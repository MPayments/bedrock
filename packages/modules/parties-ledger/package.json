    "@bedrock/test-utils": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "eslint": "^9.31.0",
    "pg": "^8.18.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
