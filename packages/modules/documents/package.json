{
  "name": "@bedrock/documents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts.ts",
    "./financial-lines": "./src/financial-lines.ts",
    "./form-types": "./src/form-types.ts",
    "./module-kit": "./src/module-kit/index.ts",
    "./schema": "./src/schema.ts",
    "./state-machine": "./src/state-machine.ts",
    "./validation": "./src/validation.ts",
    "./worker": "./src/workers/posting.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@bedrock/accounting": "workspace:*",
    "@bedrock/core": "workspace:*",
    "@bedrock/counterparties": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/customers": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "@bedrock/money": "workspace:*",
    "@bedrock/platform-auth-model": "workspace:*",
    "@bedrock/platform-crypto": "workspace:*",
    "@bedrock/platform-idempotency": "workspace:*",
    "@bedrock/platform-observability": "workspace:*",
    "@bedrock/platform-persistence": "workspace:*",
    "@bedrock/platform-worker-runtime": "workspace:*",
    "@bedrock/requisites": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bedrock/test-utils": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "bedrock": {
    "kind": "module",
    "tags": [
      "module",
      "documents"
    ]
  }
}
