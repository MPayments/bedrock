{
  "name": "@bedrock/documents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts/index.ts",
    "./model": "./src/model.ts",
    "./plugins": "./src/plugins.ts",
    "./read-model": "./src/read-model.ts",
    "./repository": "./src/infra/drizzle/repository.ts",
    "./schema": "./src/infra/drizzle/schema.ts",
    "./worker": "./src/infra/workers/posting.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@bedrock/parties": "workspace:*",
    "@bedrock/accounting": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "@bedrock/organizations": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11",
    "@bedrock/platform": "workspace:*",
    "@bedrock/shared": "workspace:*"
  },
  "devDependencies": {
    "@bedrock/test-utils": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "bedrock": {
    "kind": "module",
    "tags": [
      "module",
      "documents"
    ]
  }
}
