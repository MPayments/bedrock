{
  "name": "@bedrock/operations",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./contracts": "./src/contracts.ts",
    "./adapters/drizzle": "./src/adapters/drizzle.ts",
    "./adapters/dadata": "./src/adapters/dadata.ts",
    "./shared-ports": "./src/shared-ports.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@bedrock/calculations": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/iam": "workspace:*",
    "@bedrock/parties": "workspace:*",
    "@bedrock/platform": "workspace:*",
    "@bedrock/shared": "workspace:*",
    "@bedrock/treasury": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "@types/pg": "^8.16.0",
    "eslint": "^9.31.0",
    "pg": "^8.18.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "bedrock": {
    "kind": "module",
    "tags": [
      "module",
      "operations"
    ]
  }
