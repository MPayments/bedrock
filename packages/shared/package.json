{
  "name": "@bedrock/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./core": "./src/core/index.ts",
    "./core/*": "./src/core/*.ts",
    "./money": "./src/money/index.ts",
    "./money/*": "./src/money/*.ts",
    "./parties": "./src/parties/index.ts",
    "./parties/*": "./src/parties/*.ts",
    "./requisites": "./src/requisites/index.ts",
    "./requisites/*": "./src/requisites/*.ts",
    "./reference-data": "./src/reference-data/index.ts",
    "./reference-data/*": "./src/reference-data/*.ts",
    "./reference-data/countries": "./src/reference-data/countries/index.ts",
    "./reference-data/countries/*": "./src/reference-data/countries/*.ts"
  },
  "scripts": {
    "build": "tsgo",
    "dev": "tsc --watch",
    "check-types": "tsgo --noEmit",
    "lint": "eslint src/**/*.ts tests/**/*.ts --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bedrock/eslint-config": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "bedrock": {
    "kind": "shared",
    "tags": [
      "shared"
    ]
  }
}
