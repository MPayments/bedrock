{
  "name": "@bedrock/plugin-documents-commercial",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./contracts": "./src/contracts.ts",
    "./validation": "./src/validation.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --no-error-on-unmatched-pattern --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@bedrock/accounting": "workspace:*",
    "@bedrock/calculations": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/deals": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@bedrock/plugin-documents-sdk": "workspace:*",
    "@bedrock/shared": "workspace:*",
    "@bedrock/treasury": "workspace:*",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "bedrock": {
    "kind": "plugin",
    "tags": [
      "plugin",
      "documents",
      "commercial"
    ]
  }
}
