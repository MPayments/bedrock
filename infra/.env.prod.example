# Core runtime
NODE_ENV=production
LOG_LEVEL=error

# Public app URLs
CRM_PUBLIC_URL=https://crm.multihansa.com
FINANCE_PUBLIC_URL=https://finance.multihansa.com
PORTAL_PUBLIC_URL=https://portal.multihansa.com

# Branding
CRM_NEXT_PUBLIC_APP_TITLE=Multihansa VED CRM
CRM_NEXT_PUBLIC_APP_DESCRIPTION=Multihansa VED CRM
PORTAL_NEXT_PUBLIC_APP_TITLE=Multihansa Portal
PORTAL_NEXT_PUBLIC_APP_DESCRIPTION=Multihansa customer portal

# Shared database
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=bedrock
DB_USER=bedrock
DB_PASSWORD=replace-me
DB_SSL=false

# TigerBeetle
TB_ADDRESS=bedrock-tigerbeetle:3000
TB_CLUSTER_ID=1

# Internal service routing
API_INTERNAL_URL=http://bedrock-api:3000
CRM_ACTIVITY_UPSTREAM_URL=http://bedrock-api:3000/v1/activity

# Better Auth
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_TRUSTED_ORIGINS=https://crm.multihansa.com,https://finance.multihansa.com,https://portal.multihansa.com
BETTER_AUTH_CRM_URL=https://crm.multihansa.com
BETTER_AUTH_FINANCE_URL=https://finance.multihansa.com
BETTER_AUTH_PORTAL_URL=https://portal.multihansa.com
BETTER_AUTH_CRM_TRUSTED_ORIGINS=https://crm.multihansa.com
BETTER_AUTH_FINANCE_TRUSTED_ORIGINS=https://finance.multihansa.com
BETTER_AUTH_PORTAL_TRUSTED_ORIGINS=https://portal.multihansa.com

# Required DB seed bootstrap admin
BEDROCK_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BEDROCK_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password
BEDROCK_BOOTSTRAP_ADMIN_NAME=Admin
BEDROCK_BOOTSTRAP_ADMIN_ID=

# Optional integrations
OPENAI_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@bedrock.app
# Backend should talk to RustFS over the internal Docker network.
S3_ENDPOINT=http://bedrock-rustfs:9000
# Browser downloads use signed URLs against the public hostname.
S3_PUBLIC_ENDPOINT=https://s3.multihansa.com
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=replace-me
S3_BUCKET=bedrock-documents
S3_REGION=us-east-1

# Optional worker tuning
LEDGER_WORKER_INTERVAL_MS=5000
DOCUMENTS_WORKER_INTERVAL_MS=5000
DOCUMENTS_PERIOD_CLOSE_WORKER_INTERVAL_MS=60000
BALANCES_WORKER_INTERVAL_MS=5000
TREASURY_RATES_WORKER_INTERVAL_MS=60000

# Payment-steps dual-write kill-switch. The new primitive is enabled by
# default; set to `false` only to roll back onto the legacy leg/operation
# write path (removed entirely in commit 19).
# PAYMENT_STEPS_ENABLED=false
