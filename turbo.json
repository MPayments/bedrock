{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_CRM_TRUSTED_ORIGINS",
    "BETTER_AUTH_FINANCE_TRUSTED_ORIGINS",
    "BETTER_AUTH_CRM_URL",
    "BETTER_AUTH_FINANCE_URL",
    "BETTER_AUTH_PORTAL_URL",
    "BETTER_AUTH_PORTAL_TRUSTED_ORIGINS",
    "BETTER_AUTH_TRUSTED_ORIGINS",
    "BETTER_AUTH_URL",
    "API_INTERNAL_URL",
    "DATABASE_URL",
    "DB_HOST",
    "DB_NAME",
    "DB_PASSWORD",
    "DB_PORT",
    "DB_USER",
    "BALANCES_WORKER_INTERVAL_MS",
    "DOCUMENTS_WORKER_INTERVAL_MS",
    "DOCUMENTS_PERIOD_CLOSE_WORKER_INTERVAL_MS",
    "DEAL_ATTACHMENT_INGESTION_WORKER_INTERVAL_MS",
    "TREASURY_RATES_WORKER_INTERVAL_MS",
    "LEDGER_WORKER_INTERVAL_MS",
    "OPS_S3_CLEANUP_WORKER_INTERVAL_MS",
    "OPS_ACTIVITY_LOG_CLEANUP_WORKER_INTERVAL_MS",
    "LOG_LEVEL",
    "NODE_ENV",
    "PORT",
    "RECONCILIATION_WORKER_INTERVAL_MS",
    "TB_ADDRESS",
    "TB_CLUSTER_ID",
    "ENABLE_EXTERNAL_API_TESTS",
    "NEXT_PUBLIC_APP_DESCRIPTION",
    "NEXT_PUBLIC_APP_TITLE",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_PUBLIC_CRM_URL",
    "NEXT_PUBLIC_PORTAL_URL",
    "DB_SSL",
    "S3_ACCESS_KEY",
    "S3_BUCKET",
    "S3_ENDPOINT",
    "S3_PUBLIC_ENDPOINT",
    "S3_REGION",
    "S3_SECRET_KEY",
    "BIC_DIRECTORY_SOURCE_URL",
    "BIC_DIRECTORY_SOURCE_FILE",
    "BIC_DIRECTORY_FETCH_TIMEOUT_MS",
    "BIC_DIRECTORY_SKIP"
  ],
  "tasks": {
    "build": {
      "env": ["VERCEL"],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".vercel/output/**"]
    },
    "@bedrock/sdk-api-client#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "^build"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "finance#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["api#build", "@bedrock/sdk-api-client#build"]
    },
    "crm#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["api#build"]
    },
    "portal#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["api#build"]
    }
  }
}
