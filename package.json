{
  "name": "bedrock",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency 30",
    "lint": "turbo run lint",
    "check:boundaries": "node ./scripts/check-boundaries.mjs && node ./scripts/check-accounting-literals.mjs && node ./scripts/check-deprecated-imports.mjs",
    "check:worker-runtime": "node ./scripts/check-worker-runtime.mjs",
    "check:workspace-deps": "node ./scripts/check-workspace-deps.mjs",
    "check:graph:build": "turbo run build --dry",
    "check:graph:types": "turbo run check-types --dry",
    "check:graph": "bun run check:graph:build && bun run check:graph:types",
    "pack:validate": "bun run --filter=@bedrock/accounting pack:validate",
    "pack:compile": "bun run --filter=@bedrock/accounting pack:compile",
    "pack:activate": "bun run --filter=@bedrock/accounting pack:activate",
    "check-types": "turbo run check-types",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:integration": "vitest run --project accounting:integration --project balances:integration --project fees:integration --project fx:integration --project ledger:integration --project parties:integration --project parties-ledger:integration --project reconciliation:integration",
    "test:integration:watch": "vitest --project accounting:integration --project balances:integration --project fees:integration --project fx:integration --project ledger:integration --project parties:integration --project parties-ledger:integration --project reconciliation:integration",
    "test:all": "bun run test && bun run test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "@vitest/coverage-v8": "^4.0.18",
    "knip": "^5.85.0",
    "pg": "^8.18.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/foundation/*",
    "packages/modules/*",
    "packages/workflows/*",
    "packages/queries/*",
    "packages/queries/*/*",
    "packages/integrations/*",
    "packages/adapters/*",
    "packages/extensions/*",
    "packages/clients/*",
    "packages/ui/*",
    "packages/tooling/*",
    "ops/bootstrap/db"
  ]
}
