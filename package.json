{
  "name": "bedrock",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "db:generate": "bun run --filter=db db:generate",
    "db:migrate": "bun run --filter=db db:migrate",
    "db:nuke": "bun run --filter=db db:nuke",
    "db:push": "bun run --filter=db db:push",
    "db:seed": "bun run --filter=db db:seed",
    "db:seed:accounting": "bun run --filter=db db:seed:accounting",
    "db:bootstrap:accounting": "bun run --filter=db db:bootstrap:accounting",
    "db:seed:users": "bun run --filter=db db:seed:users",
    "db:seed:counterparties": "bun run --filter=db db:seed:counterparties",
    "db:seed:organizations": "bun run --filter=db db:seed:organizations",
    "db:seed:requisite-providers": "bun run --filter=db db:seed:requisite-providers",
    "db:seed:requisites": "bun run --filter=db db:seed:requisites",
    "db:studio": "bun run --filter=db db:studio",
    "dev": "turbo run dev --filter=api --filter=workers --filter=crm --filter=finance --filter=portal --concurrency 8",
    "dev:all": "turbo run dev --concurrency 50",
    "dev:api": "turbo run dev --filter=api",
    "dev:crm": "turbo run dev --filter=crm",
    "dev:finance": "turbo run dev --filter=finance",
    "dev:portal": "turbo run dev --filter=portal",
    "dev:workers": "turbo run dev --filter=workers",
    "lint": "turbo run lint",
    "check:architecture": "node ./scripts/check-architecture.mjs",
    "check:manifests": "node ./scripts/check-manifests.mjs",
    "check:hotspots": "node ./scripts/check-hotspots.mjs",
    "check:boundaries": "bun run check:architecture && bun run check:manifests",
    "check:cycles": "bun run check:architecture",
    "check:workspace-deps": "bun run check:manifests",
    "check:graph:build": "turbo run build --dry",
    "check:graph:types": "turbo run check-types --dry",
    "check:graph": "bun run check:graph:build && bun run check:graph:types",
    "pack:validate": "bun run --filter=@bedrock/accounting pack:validate",
    "pack:compile": "bun run --filter=@bedrock/accounting pack:compile",
    "pack:activate": "bun run --filter=@bedrock/accounting pack:activate",
    "check-types": "turbo run check-types",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts --maxWorkers=1 --project accounting:integration --project agreements:integration --project calculations:integration --project deals:integration --project documents:integration --project parties:integration --project treasury:integration --project ledger:integration --project reconciliation:integration",
    "test:integration:watch": "vitest --config vitest.integration.config.ts --maxWorkers=1 --project accounting:integration --project agreements:integration --project calculations:integration --project deals:integration --project documents:integration --project parties:integration --project treasury:integration --project ledger:integration --project reconciliation:integration",
    "test:all": "bun run test && bun run test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@typescript/native-preview": "^7.0.0-dev.20260409.1",
    "@vitest/coverage-v8": "^4.1.4",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^10.2.0",
    "knip": "^5.85.0",
    "pg": "^8.18.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/shared",
    "packages/modules/*",
    "packages/platform",
    "packages/plugins/*",
    "packages/sdk/*",
    "packages/workflows/*",
    "packages/tooling/*"
  ],
  "patchedDependencies": {
    "tlsclientwrapper@4.1.2": "patches/tlsclientwrapper@4.1.2.patch"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
