{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "exclude": [
        "exports",
        "types",
        "duplicates"
    ],
    "ignore": [
        "apps/api/build.mjs",
        "apps/workers/build.mjs",
        "packages/sdk/api-client/src/index.{js,d.ts,d.ts.map}"
    ],
    "ignoreDependencies": [
        "esbuild",
        "pino-pretty",
        "@tailwindcss/postcss"
    ],
    "ignoreUnresolved": [
        "next"
    ],
    "tags": [
        "-lintignore"
    ],
    "workspaces": {
        ".": {
            "entry": [
                "package.json",
                "*.config.{js,ts,mjs,cjs}",
                "scripts/**/*.{js,mjs,ts}",
                "tests/**/*.{js,ts}"
            ],
            "project": [
                "package.json",
                "*.config.{js,ts,mjs,cjs}",
                "scripts/**/*.{js,mjs,ts}",
                "tests/**/*.{js,ts}"
            ]
        }
    }
}
