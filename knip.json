{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "ignoreDependencies": [
        "pino-pretty",
        "@tailwindcss/postcss"
    ],
    "ignoreUnresolved": [
        "next"
    ],
    "eslint": {
        "config": [
            "eslint/**/*.mjs",
            "apps/**/eslint.config.{js,cjs,mjs}",
            "packages/**/eslint.config.{js,cjs,mjs}"
        ]
    },
    "vitest": {
        "config": [
            "vitest.config.ts",
            "apps/**/vitest.config.ts",
            "packages/**/vitest.config.ts"
        ]
    },
    "tags": [
        "-lintignore"
    ],
  "workspaces": {
    ".": {
      "ignore": [
        "packages/common/tests/workers/workers.test.ts"
      ]
    }
  }
}
