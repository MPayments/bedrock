{
  "name": "multihansa-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint src/**/*.ts --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/client": "workspace:*",
    "@bedrock/core": "workspace:*",
    "@multihansa/app": "workspace:*",
    "@multihansa/db": "workspace:*",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
