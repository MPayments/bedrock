{
  "name": "multihansa-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint src/**/*.ts --max-warnings 0"
  },
  "dependencies": {
    "@bedrock/accounting": "workspace:*",
    "@multihansa/accounting-reporting": "workspace:*",
    "@bedrock/assets": "workspace:*",
    "@bedrock/balances": "workspace:*",
    "@multihansa/counterparties": "workspace:*",
    "@multihansa/customers": "workspace:*",
    "@multihansa/db": "workspace:*",
    "@multihansa/app": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@multihansa/fees": "workspace:*",
    "@multihansa/fx": "workspace:*",
    "@bedrock/identity": "workspace:*",
    "@multihansa/ifrs-documents": "workspace:*",
    "@bedrock/kernel": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "@bedrock/modules": "workspace:*",
    "@bedrock/operations": "workspace:*",
    "@multihansa/organizations": "workspace:*",
    "@multihansa/payments": "workspace:*",
    "@multihansa/requisite-providers": "workspace:*",
    "@multihansa/requisites": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.9.44",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "hono": "^4.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@multihansa/eslint-config": "workspace:*",
    "@multihansa/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
