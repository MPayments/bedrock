{
  "name": "multihansa-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "check-types": "tsgo --noEmit --project tsconfig.json",
    "lint": "eslint src/**/*.ts --max-warnings 0"
  },
  "dependencies": {
    "@multihansa/app": "workspace:*",
    "@multihansa/accounting": "workspace:*",
    "@multihansa/assets": "workspace:*",
    "@multihansa/balances": "workspace:*",
    "@multihansa/common": "workspace:*",
    "@multihansa/db": "workspace:*",
    "@multihansa/documents": "workspace:*",
    "@multihansa/identity": "workspace:*",
    "@multihansa/ledger": "workspace:*",
    "@multihansa/parties": "workspace:*",
    "@multihansa/reporting": "workspace:*",
    "@multihansa/treasury": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.9.44",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "hono": "^4.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24",
    "eslint": "^9.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
