    "dev": "tsx watch src/main.ts all",
    "worker:all": "tsx src/main.ts all",
    "worker:ledger": "tsx src/main.ts ledger",
    "worker:documents": "tsx src/main.ts documents",
    "worker:documents-period-close": "tsx src/main.ts documents-period-close",
    "worker:balances": "tsx src/main.ts balances",
    "worker:fx-rates": "tsx src/main.ts fx-rates",
