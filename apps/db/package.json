{
  "name": "db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:nuke": "tsx ./src/nuke.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:seed": "tsx ./src/seeds/run-all.ts",
    "db:seed:accounting": "tsx ./src/seeds/run-accounting.ts",
    "db:seed:agreements": "tsx ./src/seeds/run-agreements.ts",
    "db:bootstrap:accounting": "tsx ./src/seeds/run-accounting.ts",
    "db:cutover:route-composer": "tsx ./src/cutover/run-route-composer-cutover.ts",
    "db:cutover:route-composer:backup": "tsx ./src/cutover/run-route-composer-backup.ts",
    "db:cutover:route-composer:check": "tsx ./src/cutover/run-route-composer-check.ts",
    "db:cutover:route-composer:etl": "tsx ./src/cutover/run-route-composer-etl.ts",
    "db:seed:route-templates": "tsx ./src/seeds/run-route-templates.ts",
    "db:seed:users": "tsx ./src/seeds/run-users.ts",
    "db:seed:counterparties": "tsx ./src/seeds/run-counterparties.ts",
    "db:seed:organizations": "tsx ./src/seeds/run-organizations.ts",
    "db:seed:organization-assets": "tsx ./src/seeds/run-organization-assets.ts",
    "db:seed:requisite-providers": "tsx ./src/seeds/run-requisite-providers.ts",
    "db:seed:requisites": "tsx ./src/seeds/run-requisites.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "dev": "tsc --watch -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --max-warnings 0",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@bedrock/accounting": "workspace:*",
    "@bedrock/agreements": "workspace:*",
    "@bedrock/calculations": "workspace:*",
    "@bedrock/currencies": "workspace:*",
    "@bedrock/deals": "workspace:*",
    "@bedrock/documents": "workspace:*",
    "@bedrock/files": "workspace:*",
    "@bedrock/iam": "workspace:*",
    "@bedrock/ledger": "workspace:*",
    "@bedrock/parties": "workspace:*",
    "@bedrock/platform": "workspace:*",
    "@bedrock/reconciliation": "workspace:*",
    "@bedrock/treasury": "workspace:*",
    "better-auth": "^1.4.18",
    "crm": "workspace:*",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@bedrock/eslint-config": "workspace:*",
    "@bedrock/typescript-config": "workspace:*",
    "@types/node": "^24",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "bedrock": {
    "kind": "app",
    "tags": [
      "app",
      "db"
    ]
  }
}
