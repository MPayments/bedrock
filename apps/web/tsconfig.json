{
  "extends": "@bedrock/typescript-config/nextjs.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "*": ["./*"],
      "@/*": ["./*"],
      "@bedrock/ui/globals.css": ["../../packages/sdk/ui/src/styles/globals.css"],
      "@bedrock/ui/*": ["../../packages/sdk/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
